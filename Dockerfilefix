# ==============================================
# 多架构 Dockerfile - 修复工作目录
# ==============================================

# 前端构建阶段 - 使用多架构 node 镜像
FROM node:20-alpine AS frontend-builder

# 安装 yarn
RUN apk add --no-cache yarn

WORKDIR /app/chuan-next

# 复制所有源代码
COPY chuan-next/ ./

# 清理构建文件
RUN rm -rf .next out

# 前端依赖和构建
COPY chuan-next/package.json chuan-next/yarn.lock ./
RUN yarn install --frozen-lockfile --network-timeout 300000

# 构建前端
RUN if [ -d "src/app/api" ]; then mv src/app/api /tmp/api-backup; fi && \
    NEXT_EXPORT=true NODE_ENV=production NEXT_PUBLIC_BACKEND_URL= NEXT_PUBLIC_WS_URL= NEXT_PUBLIC_API_BASE_URL= yarn build && \
    if [ -d "/tmp/api-backup" ]; then mv /tmp/api-backup src/app/api; fi

# ==============================================

# Go 构建阶段 - 支持多架构
FROM golang:1.21-alpine AS go-builder

# 安装构建依赖
RUN apk add --no-cache git ca-certificates tzdata

# 使用 TARGETARCH 构建参数来自动设置架构
ARG TARGETARCH
ARG TARGETOS=linux

# 设置 Go 环境变量
ENV GOPROXY=https://proxy.golang.org,direct
ENV CGO_ENABLED=0
ENV GOOS=${TARGETOS}
ENV GOARCH=${TARGETARCH}

# 针对 ARM64 架构的特殊处理
RUN if [ "${TARGETARCH}" = "arm64" ]; then \
      echo "Building for ARM64 architecture" && \
      apk add --no-cache gcc musl-dev; \
    fi

WORKDIR /app

# 先复制所有源代码
COPY . .

# Go 依赖
COPY go.mod go.sum ./
RUN go mod download

# 拷贝前端构建结果 - 注意正确的源路径
COPY --from=frontend-builder /app/chuan-next/out ./internal/web/frontend/

# 构建 Go 应用 - 根据目标架构自动构建
RUN echo "Building Go binary for ${GOOS}/${GOARCH}" && \
    go build -ldflags='-s -w -extldflags "-static"' -o server ./cmd

# ==============================================

# 最终镜像 - 使用多架构 alpine 镜像
FROM alpine:3.18

# 添加必要的包
RUN apk add --no-cache ca-certificates tzdata && \
    adduser -D -s /bin/sh appuser

WORKDIR /app
COPY --from=go-builder --chown=appuser:appuser /app/server ./
USER appuser

EXPOSE 8080
CMD ["./server"]
